.container {
  padding: 30rpx;
}

.title {
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.item.gold {
  border: 3rpx solid #f0ad4e;
  background: linear-gradient(135deg, #fffbe6, #fff);
}

.item.silver {
  border: 3rpx solid #bbb;
  background: linear-gradient(135deg, #f5f5f5, #fff);
}

.item.bronze {
  border: 3rpx solid #d4a574;
  background: linear-gradient(135deg, #fef5ee, #fff);
}

.rank {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #666;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.score {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
}

.score-val {
  font-size: 48rpx;
  font-weight: bold;
  color: #1aad19;
}

.score-label {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  font-size: 30rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 120rpx 0;
  font-size: 32rpx;
  color: #999;
}
