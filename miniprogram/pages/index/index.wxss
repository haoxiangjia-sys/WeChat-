.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #1aad19;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

.card {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 60rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.input {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 32rpx;
  background: #fafafa;
}

.start-btn {
  width: 100%;
  background: #1aad19;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 48rpx;
  padding: 24rpx;
  text-align: center;
  margin-bottom: 40rpx;
}

.leaderboard-entry {
  padding: 20rpx;
}

.entry-text {
  font-size: 28rpx;
  color: #1aad19;
}
