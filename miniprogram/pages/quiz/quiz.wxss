.container {
  padding: 20rpx 30rpx;
}

.top-bar {
  margin-bottom: 30rpx;
}

.progress-bar {
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #1aad19;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.question-count {
  font-size: 26rpx;
  color: #666;
}

.timer {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.timer-warn {
  color: #e64340;
  animation: pulse 0.5s infinite alternate;
}

@keyframes pulse {
  from { transform: scale(1); }
  to { transform: scale(1.1); }
}

.score-text {
  font-size: 26rpx;
  color: #1aad19;
}

.question-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.question-text {
  font-size: 34rpx;
  line-height: 1.8;
  color: #333;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option {
  display: flex;
  align-items: center;
  background: #fff;
  border: 3rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  transition: all 0.2s;
}

.option.selected {
  border-color: #1aad19;
  background: #f0f9f0;
}

.option.correct {
  border-color: #1aad19;
  background: #e8f8e8;
}

.option.wrong {
  border-color: #e64340;
  background: #fef0f0;
}

.option-letter {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  background: #1aad19;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.option-icon {
  font-size: 32rpx;
  font-weight: bold;
  margin-left: 16rpx;
}

.option.correct .option-icon {
  color: #1aad19;
}

.option.wrong .option-icon {
  color: #e64340;
}

.timeout-hint {
  text-align: center;
  margin-top: 30rpx;
  font-size: 30rpx;
  color: #e64340;
}

.next-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #1aad19;
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  text-align: center;
  margin-top: 50rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-size: 32rpx;
  color: #999;
}

.error-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}

.error-text {
  font-size: 30rpx;
  color: #e64340;
  text-align: center;
  margin-bottom: 60rpx;
  line-height: 1.8;
  word-break: break-all;
}

.back-btn {
  width: 400rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #1aad19;
  color: #fff;
  font-size: 32rpx;
  border-radius: 40rpx;
  text-align: center;
}
