.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
}

.score-circle {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 30rpx;
  border: 12rpx solid;
}

.score-circle.excellent {
  border-color: #1aad19;
  background: linear-gradient(135deg, #e8f8e8, #fff);
}

.score-circle.good {
  border-color: #f0ad4e;
  background: linear-gradient(135deg, #fef8ee, #fff);
}

.score-circle.normal {
  border-color: #e0e0e0;
  background: linear-gradient(135deg, #f5f5f5, #fff);
}

.score-number {
  font-size: 96rpx;
  font-weight: bold;
  color: #333;
}

.score-divider {
  font-size: 48rpx;
  color: #999;
  margin: 0 8rpx;
}

.score-total {
  font-size: 48rpx;
  color: #999;
}

.result-info {
  text-align: center;
  margin-bottom: 40rpx;
}

.percentage {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.message {
  display: block;
  font-size: 30rpx;
  color: #666;
}

.nickname-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  margin-bottom: 60rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.nickname-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 16rpx;
}

.nickname-value {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn {
  width: 100%;
  font-size: 34rpx;
  border-radius: 48rpx;
  padding: 24rpx;
  text-align: center;
}

.btn-primary {
  background: #1aad19;
  color: #fff;
}

.btn-outline {
  background: #fff;
  color: #1aad19;
  border: 3rpx solid #1aad19;
}

.btn-ghost {
  background: transparent;
  color: #999;
}
