<view class="container">
  <!-- 分数展示 -->
  <view class="score-circle {{percentage >= 80 ? 'excellent' : percentage >= 60 ? 'good' : 'normal'}}">
    <text class="score-number">{{score}}</text>
    <text class="score-divider">/</text>
    <text class="score-total">{{total}}</text>
  </view>

  <view class="result-info">
    <text class="percentage">正确率 {{percentage}}%</text>
    <text class="message">{{message}}</text>
  </view>

  <!-- 昵称确认 -->
  <view class="nickname-card" wx:if="{{nickname}}">
    <text class="nickname-label">玩家</text>
    <text class="nickname-value">{{nickname}}</text>
  </view>

  <!-- 操作按钮 -->
  <view class="actions">
    <button class="btn btn-primary" bindtap="playAgain">再来一局</button>
    <button class="btn btn-outline" bindtap="goToLeaderboard">查看排行榜</button>
    <button class="btn btn-ghost" bindtap="goHome">返回首页</button>
  </view>
</view>
